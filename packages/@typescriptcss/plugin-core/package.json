{
        "name": "@typescriptcss/plugin-core",
        "version": "0.1.0",
        "author": "tseijp",
        "license": "MIT",
        "sideEffects": false,
        "private": false,
        "type": "module",
        "publishConfig": {
                "access": "public"
        },
        "repository": "tseijp/typescriptcss",
        "homepage": "https://typescriptcss.tsei.jp",
        "keywords": [
                "typescript",
                "css"
        ],
        "main": "./dist/index.cjs",
        "types": "./dist/index.d.ts",
        "module": "./dist/index.js",
        "exports": {
                "./package.json": "./package.json",
                ".": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "require": "./dist/index.cjs",
                        "default": "./dist/index.js"
                },
                "./src": {
                        "types": "./src/index.ts",
                        "import": "./src/index.ts",
                        "module": "./src/index.ts",
                        "default": "./src/index.ts"
                },
                "./src/*": {
                        "types": "./src/*.ts",
                        "import": "./src/*.ts",
                        "module": "./src/*.ts",
                        "default": "./src/*.ts"
                },
                "./*": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "require": "./dist/index.cjs",
                        "default": "./dist/index.js"
                }
        },
        "scripts": {
                "build": "tsdown --config ../../../tsdown.config.ts"
        },
        "files": [
                "dist/**/*.js",
                "dist/**/*.cjs",
                "dist/**/*.d.ts",
                "src/**/*.ts",
                "package.json",
                "README.md",
                "LICENSE"
        ],
        "dependencies": {
                "@emotion/hash": "0.9.2",
                "lightningcss": "^1.32.0",
                "ts-morph": "^27.0.2",
                "unplugin": "3.0.0"
        }
}
