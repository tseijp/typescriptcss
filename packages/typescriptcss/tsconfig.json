{
        "compilerOptions": {
                "target": "ESNext",
                "module": "ESNext",
                "moduleResolution": "Bundler",
                "allowImportingTsExtensions": true,
                "noEmit": true,
                "types": ["node"],
                "strict": true,
                "skipLibCheck": true,
                "lib": ["ESNext", "DOM"],
                "jsx": "react"
        },
        "include": ["src/**/*.ts", "test/**/*.ts"]
}
