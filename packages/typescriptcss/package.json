{
        "name": "typescriptcss",
        "version": "0.1.0",
        "author": "tseijp",
        "license": "MIT",
        "sideEffects": false,
        "private": false,
        "type": "module",
        "publishConfig": {
                "access": "public"
        },
        "repository": "tseijp/typescriptcss",
        "homepage": "https://typescriptcss.tsei.jp",
        "keywords": [
                "typescript",
                "css"
        ],
        "main": "./dist/index.cjs",
        "types": "./dist/index.d.ts",
        "module": "./dist/index.js",
        "exports": {
                "./package.json": "./package.json",
                ".": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "require": "./dist/index.cjs",
                        "default": "./dist/index.js"
                },
                "./*": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.js"
                        },
                        "require": "./dist/index.cjs",
                        "default": "./dist/index.js"
                }
        },
        "scripts": {
                "build": "tsdown"
        },
        "files": [
                "dist/**/*.js",
                "dist/**/*.cjs",
                "dist/**/*.d.ts",
                "package.json",
                "README.md",
                "LICENSE"
        ],
        "devDependencies": {
                "tsdown": "0.22.2",
                "typescript": "^5"
        }
}
