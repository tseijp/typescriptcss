{
        "name": "typescriptcss",
        "author": "tseijp",
        "version": "0.1.0",
        "license": "MIT",
        "private": false,
        "type": "module",
        "sideEffects": false,
        "scripts": {
                "dev": "cd examples/typescriptcss.com && npm run dev",
                "build": "cd examples/typescriptcss.com && NODE_OPTIONS=--experimental-strip-types npm run build",
                "start": "cd examples/typescriptcss.com && npm run start",
                "deploy": "cd examples/typescriptcss.com && npm run deploy",
                "preview": "cd examples/typescriptcss.com && npm run preview",
                "tsup": "cd packages/typescriptcss && npm run build",
                "test": "cd packages/typescriptcss && npm run test",
                "it": "cd integrations && npm run test",
                "pub": "cd packages/typescriptcss && npm publish",
                "ls": "cd packages/typescriptcss && npm publish --dry-run",
                "next": "cd packages/@typescriptcss/next && npm run build",
                "rollup": "cd packages/@typescriptcss/rollup && npm run build",
                "share": "cd packages/@typescriptcss/share && npm run build",
                "vite": "cd packages/@typescriptcss/vite && npm run build",
                "prettier": "cd packages/@typescriptcss/prettier && npm run build",
                "bundle": "npm run tsup && npm run share && npm run next & npm run rollup & npm run vite & npm run prettier"
        },
        "workspaces": [
                "examples/*",
                "packages/*",
                "packages/@typescriptcss/*"
        ],
        "devDependencies": {
                "@vitest/coverage-v8": "^4.1.6",
                "@types/node": "^20",
                "prettier": "3.8.4",
                "tsdown": "0.22.2",
                "typescript": "^5"
        }
}
