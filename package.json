{
        "name": "typescriptcss",
        "author": "tseijp",
        "version": "0.1.0",
        "license": "MIT",
        "private": false,
        "type": "module",
        "sideEffects": false,
        "scripts": {
                "dev": "cd examples/docs && npm run dev",
                "build": "cd examples/docs && NODE_OPTIONS=--experimental-strip-types npm run build",
                "start": "cd examples/docs && npm run start",
                "deploy": "cd examples/docs && npm run deploy",
                "preview": "cd examples/docs && npm run preview",
                "tsup": "cd packages/typescriptcss && npm run build",
                "test": "cd packages/typescriptcss && npm run test",
                "pub": "cd packages/typescriptcss && npm publish",
                "ls": "cd packages/typescriptcss && npm publish --dry-run",
                "_core": "cd packages/@typescriptcss/plugin-core && npm run build",
                "_next": "cd packages/@typescriptcss/plugin-next && npm run build",
                "_rollup": "cd packages/@typescriptcss/plugin-rollup && npm run build",
                "_vite": "cd packages/@typescriptcss/plugin-vite && npm run build",
                "_sort": "cd packages/@typescriptcss/prettier-sort && npm run build",
                "bundle": "npm run tsup && npm run _core && npm run _next & npm run _rollup & npm run _vite & npm run _sort"
        },
        "workspaces": [
                "examples/*",
                "packages/*",
                "packages/@typescriptcss/*"
        ],
        "devDependencies": {
                "@vitest/coverage-v8": "^4.1.6",
                "@types/node": "^20",
                "prettier": "3.8.4",
                "tsdown": "0.22.2",
                "typescript": "^5"
        }
}
